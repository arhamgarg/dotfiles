{
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-right": ["tray", "pulseaudio", "battery", "memory", "clock"],
    "hyprland/workspaces": {
        "all-outputs": true,
        "disable-scroll": true,
        "format": "{icon}",
        "format-icons": {
            "1": "ΎΕι",
            "2": "ΎΚσ",
            "3": "ΎΕκ",
            "4": "ΎΒ╗",
            "urgent": "ΎΒς",
        },
    },
    "hyprland/window": {
        "tooltip": false,
    },
    "tray": {
        "spacing": 10,
    },
    "pulseaudio": {
        "format": "{volume}% {icon} {format_source}",
        "format-muted": "Ύγσ {format_source}",
        "format-source": "{volume}% ΎΕ░",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "ΎΑξ",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"],
        },
        "on-click": "footclient -e pulsemixer",
    },
    "battery": {
        "states": {
            "warning": 20,
            "critical": 5,
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ΎΩπ",
        "format-plugged": "{capacity}% ΎΘο",
        "format-alt": "{time} {icon}",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
    },
    "memory": {
        "format": "{}% ΎΜδ",
    },
    "clock": {
        "timezone": "Asia/Kolkata",
        "tooltip-format": "<tt><big>{calendar}</big></tt>",
        "format-alt": "{:%d/%m/%Y}",
    },
}
